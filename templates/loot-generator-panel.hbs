<div class="af-loot-generator-panel">

    {{!-- ── Mode Tabs ── --}}
    <div class="af-lg-mode-tabs">
        <button class="af-lg-mode-tab {{#if (eq mode 'loot')}}active{{/if}}" data-mode="loot">
            <i class="fas fa-coins"></i> Loot Generator
        </button>
        <button class="af-lg-mode-tab {{#if (eq mode 'gathering')}}active{{/if}}" data-mode="gathering">
            <i class="fas fa-leaf"></i> Gathering
        </button>
    </div>

    {{!-- ══════════════════════════════════════════════════════════════════════ --}}
    {{!-- LOOT GENERATOR MODE                                                   --}}
    {{!-- ══════════════════════════════════════════════════════════════════════ --}}
    <div class="af-lg-loot-mode" style="{{#unless (eq mode 'loot')}}display:none{{/unless}}">

        <section class="gathering-section">
            <h3 class="gathering-section-title"><i class="fas fa-skull-crossbones"></i> Loot Parameters</h3>

            <div class="gather-row">
                <label>Challenge Rating</label>
                <select class="af-lg-cr-tier">
                    {{#each crTiers}}
                        <option value="{{this.value}}" {{#if (eq ../crTier this.value)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>
        </section>

        <section class="gathering-section">
            <h3 class="gathering-section-title"><i class="fas fa-dice-d20"></i> Quick Roll Treasure & Items</h3>
            <div class="af-lg-quick-roll-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; margin-bottom: 12px;">
                <button class="af-lg-roll-btn" data-action="currency" style="grid-column: span 2; font-weight: bold;">
                    <i class="fas fa-coins"></i> Currency
                </button>
                <button class="af-lg-roll-btn" data-action="potions">
                    <i class="fas fa-flask"></i> Potions
                </button>
                <button class="af-lg-roll-btn" data-action="scrolls">
                    <i class="fas fa-scroll"></i> Scrolls
                </button>
                <button class="af-lg-roll-btn" data-action="weapons">
                    <i class="fas fa-wand-magic-sparkles"></i> Weapons & Wands
                </button>
                <button class="af-lg-roll-btn" data-action="armor">
                    <i class="fas fa-shield-halved"></i> Armor
                </button>
                <button class="af-lg-roll-btn" data-action="rings">
                    <i class="fas fa-ring"></i> Rings
                </button>
                <button class="af-lg-roll-btn" data-action="general">
                    <i class="fas fa-magic"></i> General Magic Items
                </button>
            </div>
        </section>

        {{!-- ── Results (multiple rolls, newest first) ── --}}
        {{#if hasLootResults}}
        {{#each lootResults}}
        <section class="gathering-section af-lg-results" data-roll-index="{{this.rollIndex}}">
            <h3 class="gathering-section-title"><i class="fas fa-treasure-chest"></i> Roll #{{math this.rollIndex "+" 1}}</h3>

            {{!-- Coins --}}
            {{#if this.hasCoins}}
            <div class="af-lg-coins-result">
                <h4><i class="fas fa-coins"></i> Coins</h4>
                <ul class="af-lg-coin-list">
                    {{#each this.coins}}
                        <li class="af-lg-coin-row">
                            <input class="af-lg-coin-amount" type="number" min="0" value="{{this.amount}}" data-coin-type="{{this.type}}" title="Edit amount">
                            <span class="af-lg-coin-type">{{this.label}}</span>
                        </li>
                    {{/each}}
                </ul>
            </div>
            {{/if}}

            {{!-- Items --}}
            {{#if this.hasItems}}
            <div class="af-lg-items-result">
                <h4><i class="fas fa-magic"></i> Magic Items</h4>
                <ol class="subdirectory plain af-lg-item-list">
                    {{#each this.items}}
                    <li class="directory-item entry document item flexrow af-lg-item-row" data-item-id="{{this.id}}" data-rarity="{{this.rarity}}" >
                        <img class="thumbnail" src="{{this.img}}" alt="{{this.name}}" loading="lazy">
                        <a class="entry-name ellipsis af-rarity-{{this.rarity}}">{{this.name}}</a>
                        <span class="af-lg-item-actions">
                            <button class="af-lg-send-item-to-party" data-item-id="{{this.id}}" title="Send to Party Inventory">
                                <i class="fas fa-boxes-stacked"></i>
                            </button>
                            <button class="af-lg-reroll-item" data-item-id="{{this.id}}" data-rarity="{{this.rarity}}" title="Reroll this item">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                            <button class="af-lg-remove-item" data-item-id="{{this.id}}" title="Remove this item">
                                <i class="fas fa-trash"></i>
                            </button>
                        </span>
                    </li>
                    {{/each}}
                </ol>
            </div>
            {{/if}}

            {{#unless this.hasCoins}}
                {{#unless this.hasItems}}
                    <p class="gathering-empty-notice">No treasure rolled!</p>
                {{/unless}}
            {{/unless}}

            <div class="gathering-action af-lg-send-actions">
                <button class="af-lg-send-to-party">
                    <i class="fas fa-boxes-stacked"></i> Send to Inventory
                </button>
                <button class="af-lg-discard-roll">
                    <i class="fas fa-trash"></i> Discard Roll
                </button>
            </div>
        </section>
        {{/each}}
        {{/if}}
    </div>

    {{!-- ══════════════════════════════════════════════════════════════════════ --}}
    {{!-- GATHERING MODE (original foraging UI)                                 --}}
    {{!-- ══════════════════════════════════════════════════════════════════════ --}}
    <div class="af-lg-gathering-mode" style="{{#unless (eq mode 'gathering')}}display:none{{/unless}}">

        {{!-- ── Players in Scene ── --}}
        <section class="gathering-section gathering-players">
            <h3 class="gathering-section-title"><i class="fas fa-users"></i> Players in Scene</h3>

            {{#if sceneActors.length}}
                <div class="gathering-actor-list">
                    {{#each sceneActors}}
                        <label class="gathering-actor-row">
                            <input type="checkbox"
                                   class="gathering-player-check"
                                   data-actor-id="{{this.id}}"
                                   {{#if this.selected}}checked{{/if}}>
                            <span class="gathering-actor-name">{{this.name}} <span class="gathering-player-label">({{this.playerName}})</span></span>
                        </label>
                    {{/each}}
                </div>
                <div class="gathering-select-controls">
                    <a class="gather-select-all">All</a> /
                    <a class="gather-select-none">None</a>
                </div>
            {{else}}
                <p class="gathering-empty-notice">No player-controlled tokens in the active scene.</p>
            {{/if}}
        </section>

        {{!-- ── Gather Mode Toggle ── --}}
        <section class="gathering-section gathering-mode-section">
            <h3 class="gathering-section-title"><i class="fas fa-exchange-alt"></i> Gather Mode</h3>
            <div class="gather-mode-toggle">
                <button class="gather-mode-btn {{#if (eq gatherMode 'ingredients')}}active{{/if}}" data-mode="ingredients">
                    <i class="fas fa-leaf"></i> Ingredients
                </button>
                <button class="gather-mode-btn {{#if (eq gatherMode 'materials')}}active{{/if}}" data-mode="materials">
                    <i class="fas fa-hammer"></i> Forge Materials
                </button>
            </div>
        </section>

        {{!-- ── DC Modifiers ── --}}
        <section class="gathering-section gathering-environment">
            <h3 class="gathering-section-title"><i class="fas fa-map"></i> DC Modifiers</h3>

            <div class="gather-row">
                <label>Biome</label>
                <select class="gather-biome">
                    {{#each biomes}}
                        <option value="{{this.value}}" {{#if (eq ../biome this.value)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="gather-row">
                <label>Abundance</label>
                <select class="gather-abundance">
                    {{#each abundances}}
                        <option value="{{this.value}}" {{#if (eq ../abundance this.value)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="gather-row" style="flex-wrap: wrap;">
                <label>Time Spent</label>
                <input class="gather-time-amount" type="number" min="1" max="999" value="{{timeAmount}}">
                <select class="gather-time-unit" style="flex: 1;">
                    {{#each timeUnits}}
                        <option value="{{this.value}}" {{#if (eq ../timeUnit this.value)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
                <p class="notes" style="width: 100%; margin: 4px 0 0 0; font-size: 0.9em; opacity: 0.8;">
                    Note: 1 day of active gathering equals 8 hours.
                </p>
            </div>

            <div class="gather-row">
                <label>Weather</label>
                <select class="gather-weather">
                    {{#each weatherOptions}}
                        <option value="{{this.value}}" {{#if (eq ../weatherMod this.value)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="gather-row">
                <label>Season</label>
                <select class="gather-season">
                    {{#each seasonOptions}}
                        <option value="{{this.value}}" {{#if (eq ../seasonMod this.value)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>
        </section>

        {{!-- ── Roll Settings ── --}}
        <section class="gathering-section gathering-settings">
            <h3 class="gathering-section-title"><i class="fas fa-cog"></i> Roll Settings</h3>

            <div class="gather-row">
                <label>Skill</label>
                <select class="gather-skill">
                    {{#each skillOptions}}
                        <option value="{{this.value}}" {{#if (eq ../skillKey this.value)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="gather-row" style="flex-wrap: wrap;">
                <label>Rarity Bias</label>
                <select class="gather-rarity-mod" style="flex: 1;">
                    <option value="-5" {{#if (eq rarityMod "-5")}}selected{{/if}}>Extreme Common Focus (Common 90% | Uncommon 7.5% | Rare 1.7% | Very Rare 0.8%)</option>
                    <option value="-3" {{#if (eq rarityMod "-3")}}selected{{/if}}>Favor Common (Common 78% | Uncommon 16.5% | Rare 3.9% | Very Rare 1.6%)</option>
                    <option value="0" {{#if (eq rarityMod "0")}}selected{{/if}}>Balanced (Common 60% | Uncommon 30% | Rare 7% | Very Rare 3%)</option>
                    <option value="3" {{#if (eq rarityMod "3")}}selected{{/if}}>Favor Rare/Legend (Common 42% | Uncommon 30% | Rare 19.6% | Very Rare 8.4%)</option>
                    <option value="5" {{#if (eq rarityMod "5")}}selected{{/if}}>Extreme Rare/Legend (Common 30% | Uncommon 30% | Rare 28% | Very Rare 12%)</option>
                </select>
                <p class="notes" style="width: 100%; margin: 4px 0 0 0; font-size: 0.9em; opacity: 0.8;">
                    Positive bias shifts weight from Common to Rare/Very Rare. Negative bias shifts weight to Common.
                </p>
            </div>
        </section>

        {{!-- ── Difficulty Class ── --}}
        <section class="gathering-section gathering-dc-section">
            <h3 class="gathering-section-title"><i class="fas fa-bullseye"></i> Difficulty Class</h3>

            <div class="gather-dc-row">
                <label>DC</label>
                <input class="dc-display" type="number" min="1" max="30" value="{{displayDC}}">
                <button class="dc-reset-btn icon-btn" title="Reset to auto" style="{{#unless isManualDC}}display:none{{/unless}}">
                    <i class="fas fa-undo"></i>
                </button>
            </div>
        </section>

        {{!-- ── Foraging Preview ── --}}
        <section class="gathering-section foraging-preview-section">
            <h3 class="gathering-section-title"><i class="fas fa-eye"></i> Foraging Preview</h3>
            <div class="preview-row">
                <span class="preview-label">Expected Yield:</span>
                <span class="preview-value expected-yield-value">{{expectedQtyLabel}}</span>
            </div>
            <div class="preview-rarity-distribution">
                <div class="rarity-distribution-title">Base Biome Composition:</div>
                <div class="rarity-bar-wrapper">
                    <div class="rarity-bar-item">
                        <div class="rarity-bar-label">Common: {{previewRarities.common}}%</div>
                        <div class="rarity-bar-progress-bg">
                            <div class="rarity-bar-progress progress-common" style="width: {{previewRarities.common}}%"></div>
                        </div>
                    </div>
                    <div class="rarity-bar-item">
                        <div class="rarity-bar-label">Uncommon: {{previewRarities.uncommon}}%</div>
                        <div class="rarity-bar-progress-bg">
                            <div class="rarity-bar-progress progress-uncommon" style="width: {{previewRarities.uncommon}}%"></div>
                        </div>
                    </div>
                    <div class="rarity-bar-item">
                        <div class="rarity-bar-label">Rare: {{previewRarities.rare}}%</div>
                        <div class="rarity-bar-progress-bg">
                            <div class="rarity-bar-progress progress-rare" style="width: {{previewRarities.rare}}%"></div>
                        </div>
                    </div>
                    <div class="rarity-bar-item">
                        <div class="rarity-bar-label">Very Rare+: {{previewRarities.veryRare}}%</div>
                        <div class="rarity-bar-progress-bg">
                            <div class="rarity-bar-progress progress-veryrare" style="width: {{previewRarities.veryRare}}%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {{!-- ── Action ── --}}
        <div class="gathering-action">
            <button class="request-roll-btn">
                <i class="fas fa-dice-d20"></i> Request Roll
            </button>
        </div>
    </div>

</div>
