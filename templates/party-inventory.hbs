<div class="af-party-inventory-panel">

    {{!-- ── Character Select ── --}}
    {{#if ownedActors.length}}
    <section class="gathering-section af-pi-char-section">
        <div class="gather-row">
            <label>Character</label>
            <select class="af-pi-actor-select">
                {{#each ownedActors}}
                    <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
            </select>
        </div>
    </section>
    {{/if}}

    {{!-- ── Coins ── --}}
    <section class="gathering-section af-pi-coins-section">
        <h3 class="gathering-section-title"><i class="fas fa-coins"></i> Coins</h3>
        <div class="af-pi-coin-grid">
            <div class="af-pi-coin-header">
                <span class="af-pi-coin-hdr-icon"></span>
                <span class="af-pi-coin-hdr-total">Total</span>
                <span class="af-pi-coin-hdr-take">Take</span>
                <span class="af-pi-coin-hdr-btn"></span>
            </div>
            {{#each coins}}
            <div class="af-pi-coin-row" data-coin-type="{{this.type}}">
                <img class="af-pi-coin-icon" src="{{this.icon}}" alt="{{this.label}}" title="{{this.label}} ({{this.abbr}})">
                <input type="number" class="af-pi-coin-total" data-coin-type="{{this.type}}"
                       min="0" value="{{this.amount}}" title="Edit {{this.label}} total">
                <input type="number" class="af-pi-coin-take-amount" data-coin-type="{{this.type}}"
                       min="0" max="{{this.amount}}" value="" placeholder="0" title="Amount to take">
                <button class="af-pi-coin-take-btn" data-coin-type="{{this.type}}" title="Take {{this.label}}">
                    <i class="fas fa-arrow-right"></i>
                </button>
            </div>
            {{/each}}
        </div>
        <div class="af-pi-coin-actions">
            <button class="af-pi-take-all-coins"><i class="fas fa-coins"></i> Take All Coins</button>
        </div>
    </section>

    {{!-- ── Items (draggable, Foundry-native style) ── --}}
    {{#if hasItems}}
    <section class="gathering-section af-pi-items-section">
        <h3 class="gathering-section-title"><i class="fas fa-magic"></i> Items</h3>
        <p class="af-pi-drag-hint"><i class="fas fa-arrows-alt"></i> Drag items to a character sheet, or use the buttons below</p>
        <ol class="subdirectory plain af-pi-item-list">
            {{#each items}}
            <li class="directory-item entry document item flexrow af-pi-item-row" data-item-id="{{this.id}}" draggable="true" >
                <img class="thumbnail" src="{{this.img}}" alt="{{this.name}}" loading="lazy">
                <a class="entry-name ellipsis af-rarity-{{this.rarity}}">{{this.name}}</a>
                <div class="af-pi-item-actions">
                    <button class="af-pi-take-item-btn" data-item-id="{{this.id}}" title="Take to character">
                        <i class="fas fa-arrow-right"></i>
                    </button>
                    <button class="af-pi-remove-item-btn" data-item-id="{{this.id}}" title="Remove from inventory">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </li>
            {{/each}}
        </ol>
    </section>
    {{/if}}

    {{!-- ── Empty State ── --}}
    {{#if isEmpty}}
    <div class="af-pi-empty">
        <p class="gathering-empty-notice"><i class="fas fa-box-open"></i> The party inventory is empty.</p>
        <p class="gathering-empty-notice">Use the Loot Generator to roll treasure, then send it here.</p>
        <p class="gathering-empty-notice">You can also drag items from character sheets here.</p>
    </div>
    {{/if}}

    {{!-- ── GM: Clear Inventory ── --}}
    {{#if isGM}}
    {{#unless isEmpty}}
    <section class="gathering-section af-pi-admin-section">
        <button class="af-pi-clear-btn" title="Permanently delete all party inventory contents">
            <i class="fas fa-trash"></i> Clear Inventory
        </button>
    </section>
    {{/unless}}
    {{/if}}

</div>
