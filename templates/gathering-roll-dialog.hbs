<div class="af-gathering-roll-body">
    <div class="gathering-roll-actor">
        <i class="fas fa-user"></i>
        <strong>{{actorName}}</strong>
    </div>

    <p class="gathering-roll-prompt">
        Roll <strong>{{skillLabel}}</strong> to gather ingredients.
    </p>

    <div class="gathering-roll-actions">
        <button class="do-gather-roll">
            <i class="fas fa-dice-d20"></i> Roll {{skillLabel}}
        </button>
    </div>
</div>
