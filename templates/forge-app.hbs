<div class="crafting-panels-layout">

    {{!-- LEFT PANEL — Blueprint List --}}
    <div class="panel recipe-list-panel">
        <div class="panel-header">
            <h2><i class="fas fa-scroll"></i> Blueprints</h2>
        </div>

        <div class="recipe-filters">
            <input class="search-input" type="text" placeholder="Search blueprints…" value="{{searchQuery}}">
            <select class="filter-learned">
                <option value="all" {{#if (eq filterLearned "all")}}selected{{/if}}>All Blueprints</option>
                <option value="known" {{#if (eq filterLearned "known")}}selected{{/if}}>Known</option>
                <option value="unknown" {{#if (eq filterLearned "unknown")}}selected{{/if}}>Unknown</option>
            </select>
            <select class="filter-rarity">
                <option value="all" {{#if (eq filterRarity "all")}}selected{{/if}}>All Rarities</option>
                <option value="common" {{#if (eq filterRarity "common")}}selected{{/if}}>Common</option>
                <option value="uncommon" {{#if (eq filterRarity "uncommon")}}selected{{/if}}>Uncommon</option>
                <option value="rare" {{#if (eq filterRarity "rare")}}selected{{/if}}>Rare</option>
                <option value="very_rare" {{#if (eq filterRarity "very_rare")}}selected{{/if}}>Very Rare</option>
                <option value="legendary" {{#if (eq filterRarity "legendary")}}selected{{/if}}>Legendary</option>
            </select>
            <select class="filter-category">
                <option value="all" {{#if (eq filterCategory "all")}}selected{{/if}}>All Types</option>
                <option value="weapon" {{#if (eq filterCategory "weapon")}}selected{{/if}}>Weapons</option>
                <option value="armor" {{#if (eq filterCategory "armor")}}selected{{/if}}>Armor</option>
                <option value="shield" {{#if (eq filterCategory "shield")}}selected{{/if}}>Shields</option>
                <option value="wondrous" {{#if (eq filterCategory "wondrous")}}selected{{/if}}>Wondrous</option>
                <option value="ammunition" {{#if (eq filterCategory "ammunition")}}selected{{/if}}>Ammunition</option>
            </select>
        </div>

        <div class="recipe-list">
            {{#each recipes}}
                <div class="recipe-item rarity-{{this.rarity}} {{#unless this.isLearned}}unknown{{/unless}} {{#if (eq ../selectedRecipe.id this.id)}}selected{{/if}}"
                     data-recipe-id="{{this.id}}">
                    <div class="recipe-item-header">
                        <span class="recipe-name">
                            {{#unless this.isLearned}}<i class="fas fa-lock" title="Unknown"></i> {{/unless}}
                            {{this.name}}
                        </span>
                        <div class="recipe-actions">
                            {{#if this.isLearned}}
                                <i class="fas fa-check-circle known-badge" title="Known"></i>
                                <a class="forget-recipe-btn" data-recipe-id="{{this.id}}" title="Forget"><i class="fas fa-trash-alt"></i></a>
                            {{else}}
                                <a class="learn-recipe-btn" data-recipe-id="{{this.id}}" title="Teach"><i class="fas fa-graduation-cap"></i></a>
                            {{/if}}
                        </div>
                    </div>
                    <div class="recipe-item-meta">
                        <span class="rarity-badge rarity-{{this.rarity}}">{{rarityLabel this.rarity}}</span>
                        <span class="category-badge"><i class="fas fa-tag"></i> {{this.category}}</span>
                        <span class="time-badge"><i class="fas fa-clock"></i> {{this.craftingTimeLabel}}</span>
                        <span class="cost-badge"><i class="fas fa-coins"></i> {{this.craftingCost}} gp</span>
                    </div>
                </div>
            {{else}}
                <p class="empty-list">No blueprints match your filters.</p>
            {{/each}}
        </div>
    </div>

    {{!-- CENTER PANEL — Forge Station with Rune Circle --}}
    <div class="panel crafting-station-panel">
        <div class="panel-header">
            <h2><i class="fas fa-hammer"></i> Forge Station
                {{#if isSmith}}<span class="alchemist-badge"><i class="fas fa-hammer"></i> Smith</span>{{/if}}
            </h2>
        </div>

        {{#if selectedRecipe}}
            <div class="selected-recipe-header rarity-bg-{{selectedRecipe.rarity}}">
                <h3>{{selectedRecipe.name}}</h3>
                <div class="selected-recipe-meta">
                    <span class="rarity-badge rarity-{{selectedRecipe.rarity}}">{{rarityLabel selectedRecipe.rarity}}</span>
                    <span class="category-badge"><i class="fas fa-tag"></i> {{selectedRecipe.category}}</span>
                    <span class="time-badge"><i class="fas fa-clock"></i> {{selectedRecipe.craftingTimeLabel}}</span>
                    <span class="cost-badge"><i class="fas fa-coins"></i> {{selectedRecipe.craftingCost}} gp</span>
                    {{#unless selectedRecipe.isLearned}}<span class="unknown-badge"><i class="fas fa-lock"></i> Unknown</span>{{/unless}}
                </div>
                <p class="recipe-description">{{selectedRecipe.description}}</p>
            </div>

            {{!-- Rune Circle --}}
            <div class="rune-circle-container {{#if crafting}}crafting{{/if}} {{#if canCraft}}all-filled{{/if}} rune-rarity-{{selectedRecipe.rarity}}">
                <div class="rune-circle-svg">
                    <img src="modules/artificer-foundry/assets/rune-circle.svg" alt="Forge Circle">
                </div>

                {{!-- Material Slots --}}
                <div class="rune-slots">
                    {{#each mappedIngredients}}
                        <div class="rune-slot slot-{{@index}} {{#if this.fulfilled}}filled{{/if}}" title="{{this.name}} ({{this.provided}}/{{this.quantity}})">
                            {{#if this.fulfilled}}
                                <img src="{{this.icon}}" alt="{{this.name}}" class="slot-icon">
                            {{else}}
                                <span class="slot-empty">?</span>
                            {{/if}}
                            <button class="remove-ingredient-btn slot-remove" data-ingredient-name="{{this.name}}" title="Remove">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    {{/each}}
                </div>

                {{!-- Center output --}}
                <div class="rune-center-output">
                    {{#if crafting}}
                        <img src="{{selectedRecipe.output.img}}" alt="{{selectedRecipe.output.name}}" class="crafted-item-reveal">
                    {{else}}
                        <i class="fas fa-question fa-2x center-question"></i>
                    {{/if}}
                </div>
            </div>

            {{!-- Material Requirements List --}}
            <div class="requirements">
                <h4><i class="fas fa-list-ul"></i> Required Materials</h4>
                <ul class="ingredient-list">
                    {{#each mappedIngredients}}
                        <li class="ingredient-row {{#if this.fulfilled}}fulfilled{{else}}missing{{/if}}">
                            <img src="{{this.icon}}" class="ingredient-icon" alt="">
                            <span class="ingredient-name">{{this.name}}</span>
                            <span class="ingredient-type-badge type-{{this.type}}">{{this.typeLabel}}</span>
                            <span class="ingredient-count">{{this.provided}} / {{this.quantity}}</span>
                            {{#if (gt this.substitutes.length 0)}}
                                <span class="substitute-hint" title="Also accepts: {{join this.substitutes ', '}}"><i class="fas fa-exchange-alt"></i></span>
                            {{/if}}
                        </li>
                    {{/each}}
                </ul>
            </div>

            <div class="station-controls">
                <button class="clear-station-btn" {{#unless mappedIngredients}}disabled{{/unless}}>
                    <i class="fas fa-trash"></i> Clear
                </button>
                <button class="craft-btn" {{#unless canCraft}}disabled{{/unless}}>
                    <i class="fas fa-hammer"></i>
                    {{#if canCraft}}Forge {{selectedRecipe.output.name}}{{else}}Forge Item{{/if}}
                </button>
            </div>

            {{#unless selectedRecipe.isLearned}}
                <p class="unknown-warning"><i class="fas fa-exclamation-triangle"></i> You have not yet learned this blueprint.</p>
            {{/unless}}

        {{else}}
            <div class="placeholder-area">
                <div class="rune-circle-container idle">
                    <div class="rune-circle-svg">
                        <img src="modules/artificer-foundry/assets/rune-circle.svg" alt="Forge Circle">
                    </div>
                </div>
                <p>Select a blueprint from the list to begin forging.</p>
            </div>
        {{/if}}
    </div>

    {{!-- RIGHT PANEL — Character Inventory --}}
    <div class="panel inventory-panel">
        <div class="panel-header">
            <h2><i class="fas fa-backpack"></i> Inventory
                {{#if actor}}<small>({{actor.name}})</small>{{/if}}
            </h2>
        </div>

        {{#if selectedRecipe}}
            {{#if inventoryItems.length}}
                <p class="inventory-hint">Drag or click + to add materials:</p>
                <ul class="inventory-list">
                    {{#each inventoryItems}}
                        <li class="inventory-item" data-item-id="{{this.id}}" draggable="true">
                            <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
                            <span class="item-name">{{this.name}}</span>
                            <span class="item-qty">×{{this.quantity}}</span>
                            <button class="quick-add-btn icon-btn" data-item-id="{{this.id}}" title="Add to forge">
                                <i class="fas fa-plus"></i>
                            </button>
                        </li>
                    {{/each}}
                </ul>
            {{else}}
                <div class="no-inventory">
                    <i class="fas fa-box-open fa-2x"></i>
                    <p>No matching materials in inventory.</p>
                </div>
            {{/if}}
        {{else}}
            <div class="no-inventory">
                <i class="fas fa-box fa-2x"></i>
                <p>Select a blueprint to see matching materials.</p>
            </div>
        {{/if}}
    </div>

</div>
